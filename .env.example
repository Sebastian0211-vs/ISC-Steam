# Copy to server/.env (or export in your shell)
PORT=5174
MONGODB_URI=mongodb://127.0.0.1:27017/isc-steam
CLIENT_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=change-me-to-a-long-random-string
# Code students enter at registration to get the publisher role
PUBLISHER_CODE=ISC-2026

# Build pipeline (requires git + scalac on the PATH)
# Explicit path to scala-library.jar if auto-detection from scalac fails:
#SCALA_LIBRARY_JAR=/usr/share/scala/lib/scala-library.jar
# Extra fallback jars used when a student repo does not include its dependencies.
# On Windows, separate multiple paths with ;. Commas also work on every OS.
#GAME_DEPENDENCY_JARS=server/vendor/gdx2d-demoDesktop-1.2.2.jar;server/vendor/gdx2d-desktop-1.2.2.jar;server/vendor/accordion-1.2.0-jar-with-dependencies.jar

# Linux/macOS servers only: cross-building the Windows game package needs the
# jmods/ of a Windows x64 JDK with the SAME version as the local JDK.
# (The Docker image sets these automatically.)
#WINDOWS_JDK_JMODS=/opt/windows-jdk/jmods
# Windows JavaFX jmods, for games with "javafx": true:
#JAVAFX_JMODS=/opt/javafx-jmods
