# Copy to server/.env (or export in your shell)
PORT=5174
MONGODB_URI=mongodb://127.0.0.1:27017/isc-steam
CLIENT_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=change-me-to-a-long-random-string
# Code students enter at registration to get the publisher role
PUBLISHER_CODE=ISC-2026

# Build pipeline (requires git + scalac on the PATH)
# Explicit path to scala-library.jar if auto-detection from scalac fails:
#SCALA_LIBRARY_JAR=/usr/share/scala/lib/scala-library.jar
